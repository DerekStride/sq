#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "cli/ui"

CLI::UI::StdoutRouter.enable
CLI::UI.frame_style = :box

# Mock data for testing the UI loop
MOCK_ITEMS = [
  {
    file: "app/models/user.rb",
    hunk: <<~DIFF,
      @@ -10,6 +10,8 @@ class User < ApplicationRecord
         validates :email, presence: true
      +  validates :name, length: { maximum: 255 }
      +
         has_many :posts
    DIFF
    suggestion: "Consider adding a minimum length validation as well to prevent empty names."
  },
  {
    file: "app/controllers/users_controller.rb",
    hunk: <<~DIFF,
      @@ -15,7 +15,9 @@ class UsersController < ApplicationController
         def create
      -    @user = User.new(user_params)
      +    @user = User.new(user_params)
      +    @user.created_by = current_user
      +
           if @user.save
    DIFF
    suggestion: "The `created_by` assignment could raise if `current_user` is nil. Add a guard or use `&.` safe navigation."
  },
  {
    file: "config/routes.rb",
    hunk: <<~DIFF,
      @@ -5,6 +5,7 @@ Rails.application.routes.draw do
         resources :users
      +  resources :posts, only: [:index, :show]
         root "home#index"
    DIFF
    suggestion: "Looks good! The route follows RESTful conventions."
  }
].freeze

class RoastTUI
  COMMANDS = {
    "a" => { name: "accept", desc: "Accept suggestion" },
    "r" => { name: "reject", desc: "Reject suggestion" },
    "c" => { name: "comment", desc: "Add comment" },
    "q" => { name: "quit", desc: "Quit review" }
  }.freeze

  def initialize(items)
    @items = items
    @current = 0
    @decisions = []
  end

  def run
    CLI::UI::Frame.open("{{bold:Roast Review}}", color: :blue) do
      puts CLI::UI.fmt("{{cyan:Reviewing #{@items.length} items...}}")
      puts
    end

    loop do
      break if @current >= @items.length

      item = @items[@current]
      display_item(item)

      action = prompt_action
      break if action == :quit

      record_decision(action, item)
      @current += 1
    end

    show_summary
  end

  private

  def display_item(item)
    puts
    CLI::UI::Frame.open("{{bold:#{item[:file]}}} {{cyan:(#{@current + 1}/#{@items.length})}}", color: :yellow) do
      # Display the diff hunk
      puts CLI::UI.fmt("{{bold:Diff:}}")
      item[:hunk].each_line do |line|
        formatted = case line[0]
        when "+" then CLI::UI.fmt("{{green:#{line.chomp}}}")
        when "-" then CLI::UI.fmt("{{red:#{line.chomp}}}")
        when "@" then CLI::UI.fmt("{{cyan:#{line.chomp}}}")
        else line.chomp
        end
        puts formatted
      end

      puts
      puts CLI::UI.fmt("{{bold:Suggestion:}}")
      puts CLI::UI.fmt("{{italic:#{item[:suggestion]}}}")
    end
  end

  def prompt_action
    puts
    puts CLI::UI.fmt("{{bold:Actions:}} [{{green:a}}]ccept  [{{red:r}}]eject  [{{yellow:c}}]omment  [{{cyan:q}}]uit")
    print CLI::UI.fmt("{{bold:Choice:}} ")

    loop do
      char = CLI::UI::Prompt.read_char
      case char.downcase
      when "a"
        puts CLI::UI.fmt("{{green:✓ Accepted}}")
        return :accept
      when "r"
        puts CLI::UI.fmt("{{red:✗ Rejected}}")
        return :reject
      when "c"
        puts
        comment = CLI::UI::Prompt.ask("Enter comment:")
        puts CLI::UI.fmt("{{yellow:💬 Commented}}")
        return [:comment, comment]
      when "q"
        puts CLI::UI.fmt("{{cyan:Quitting...}}")
        return :quit
      end
    end
  end

  def record_decision(action, item)
    @decisions << {
      file: item[:file],
      action: action
    }
  end

  def show_summary
    puts
    CLI::UI::Frame.open("{{bold:Review Summary}}", color: :green) do
      if @decisions.empty?
        puts CLI::UI.fmt("{{yellow:No decisions recorded.}}")
      else
        accepted = @decisions.count { |d| d[:action] == :accept }
        rejected = @decisions.count { |d| d[:action] == :reject }
        commented = @decisions.count { |d| d[:action].is_a?(Array) }

        puts CLI::UI.fmt("{{green:Accepted:}} #{accepted}")
        puts CLI::UI.fmt("{{red:Rejected:}} #{rejected}")
        puts CLI::UI.fmt("{{yellow:Commented:}} #{commented}")
        puts CLI::UI.fmt("{{cyan:Skipped:}} #{@items.length - @decisions.length}")
      end
    end
  end
end

# Run the TUI
if __FILE__ == $PROGRAM_NAME
  if ARGV.include?("--demo")
    # Demo mode: show UI without waiting for input
    CLI::UI::Frame.open("{{bold:Roast Review}}", color: :blue) do
      puts CLI::UI.fmt("{{cyan:Reviewing 3 items...}}")
    end

    item = MOCK_ITEMS.first
    puts
    CLI::UI::Frame.open("{{bold:#{item[:file]}}} {{cyan:(1/3)}}", color: :yellow) do
      puts CLI::UI.fmt("{{bold:Diff:}}")
      item[:hunk].each_line do |line|
        formatted = case line[0]
        when "+" then CLI::UI.fmt("{{green:#{line.chomp}}}")
        when "-" then CLI::UI.fmt("{{red:#{line.chomp}}}")
        when "@" then CLI::UI.fmt("{{cyan:#{line.chomp}}}")
        else line.chomp
        end
        puts formatted
      end
      puts
      puts CLI::UI.fmt("{{bold:Suggestion:}}")
      puts CLI::UI.fmt("{{italic:#{item[:suggestion]}}}")
    end

    puts
    puts CLI::UI.fmt("{{bold:Actions:}} [{{green:a}}]ccept  [{{red:r}}]eject  [{{yellow:c}}]omment  [{{cyan:q}}]uit")
    puts CLI::UI.fmt("{{bold:Choice:}} {{gray:(demo mode - no input)}}")
  else
    tui = RoastTUI.new(MOCK_ITEMS)
    tui.run
  end
end
